# =============================================
# Sovereign Engine - Environment Variables
# =============================================

# ================== OpenAI Settings ==================
OPENAI_API_KEY=sk-your-openai-api-key-here

# ================== Optional Settings ==================
# LOG_LEVEL=INFO
# DEBUG_MODE=true

# LLM Repair Settings
MATRIX_REPAIR_ENABLED=true
MATRIX_REPAIR_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.0

# Embedding Model
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Performance
MAX_WORKERS=6
MAX_CACHE_SIZE=500

# Paths (optional)
# REPORTS_DIR=reports
# LOGS_DIR=logs
# ARCHIVE_DIR=archive